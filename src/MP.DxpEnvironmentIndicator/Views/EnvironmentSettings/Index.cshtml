@model MP.DxpEnvironmentIndicator.Models.EnvironmentSettingsViewModel
@using MP.DxpEnvironmentIndicator.Controllers
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Enviro-helper</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body {
            font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            font-size: 14px; color: #1a1a1a; background: #fff; margin: 0; padding: 24px 28px; line-height: 1.5;
        }
        h1 { font-size: 20px; font-weight: 600; margin: 0 0 4px; }
        .sub { color: #555; margin: 0 0 20px; max-width: 720px; }
        .intro { background: #f4f8ff; border: 1px solid #d6e4fb; border-radius: 6px; padding: 14px 16px; margin-bottom: 24px; max-width: 720px; }
        .intro p { margin: 0 0 8px; }
        .intro p:last-child { margin-bottom: 0; }
        .env { border: 1px solid #e3e3e3; border-radius: 6px; padding: 16px 18px; margin-bottom: 16px; max-width: 720px; }
        .env h2 { font-size: 15px; font-weight: 600; margin: 0 0 12px; }
        label { display: block; font-size: 13px; font-weight: 500; color: #333; margin: 0 0 4px; }
        input[type=text] {
            width: 100%; max-width: 480px; padding: 7px 9px; border: 1px solid #bbb; border-radius: 3px;
            font-size: 14px; margin-bottom: 12px; background: #fff; color: #1a1a1a;
        }
        textarea {
            width: 100%; max-width: 480px; padding: 7px 9px; border: 1px solid #bbb; border-radius: 3px;
            font-size: 14px; margin-bottom: 4px; background: #fff; color: #1a1a1a;
            font-family: inherit; resize: vertical; display: block;
        }
        input[type=text]:focus, input[type=color]:focus, textarea:focus {
            outline: none; border-color: #2973c3; box-shadow: 0 0 0 2px rgba(41,115,195,0.2);
        }
        .color-row { display: flex; align-items: center; gap: 10px; }
        input[type=color] { width: 42px; height: 30px; padding: 0; border: 1px solid #bbb; border-radius: 3px; background: #fff; cursor: pointer; }
        .color-hint { color: #777; font-size: 12px; }
        .checkbox-row { display: flex; align-items: center; gap: 8px; margin: 12px 0 4px; max-width: 720px; }
        .checkbox-row label { margin: 0; font-weight: 400; }
        button {
            display: inline-block; padding: 9px 18px; font-size: 14px; font-weight: 500; cursor: pointer;
            border-radius: 3px; text-decoration: none; background: #2973c3; color: #fff; border: none;
        }
        button:hover { background: #1f5ea3; }
        .saved { background: #e8f5e9; color: #1b5e20; border: 1px solid #a5d6a7; padding: 9px 12px; border-radius: 4px; margin-bottom: 18px; max-width: 720px; }
        .error { background: #fdecea; color: #b71c1c; border: 1px solid #ef9a9a; padding: 9px 12px; border-radius: 4px; margin-bottom: 18px; max-width: 720px; }
        details.advanced { max-width: 720px; margin: 0 0 22px; border: 1px solid #e3e3e3; border-radius: 6px; }
        details.advanced > summary { cursor: pointer; padding: 12px 16px; font-weight: 600; font-size: 14px; list-style: none; user-select: none; }
        details.advanced > summary::-webkit-details-marker { display: none; }
        details.advanced > summary::before { content: '\25B8'; display: inline-block; margin-right: 8px; color: #888; transition: transform 0.15s; }
        details.advanced[open] > summary::before { transform: rotate(90deg); }
        .advanced-body { padding: 0 16px 16px; }
        .help { color: #777; font-size: 12px; margin: 0 0 12px; max-width: 640px; }
        code { background: #f3f4f6; border: 1px solid #e3e3e3; border-radius: 3px; padding: 1px 5px; font-size: 12px; word-break: break-all; }
        input[type=submit] { height: 40px; }
        .env-disabled { opacity: 0.5; }
    </style>
</head>
<body>
    <h1>Enviro-helper</h1>
    <p class="sub">Badge the current DXP environment into the CMS top bar so editors always know where they are.</p>

    @if (Model.Saved)
    {
        <div class="saved">&#10003; Settings saved.</div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="error">@Model.ErrorMessage</div>
    }

    <div class="intro">
        <p><strong>How it works:</strong> enter the <em>Base URLs</em> for each environment. The running site identifies
        itself by matching the browser's request host against these URLs — so the same settings can be saved on every
        environment, and each one badges itself correctly.</p>
        <p>Host-matching is used (rather than a stored "this is X" flag) because it can't be clobbered when DXP copies
        database content between environments. Only the host part of each URL is compared; port and scheme are ignored.</p>
    </div>

    <form method="post" action="@Context.Request.Path">
        @Html.AntiForgeryToken()

        <div class="env">
            <h2>Integration</h2>
            <label for="i-url">Base URLs</label>
            <textarea id="i-url" name="IntegrationBaseUrl" rows="3"
                placeholder="https://your-inte-slot.dxcloud.episerver.net">@Model.IntegrationBaseUrl</textarea>
            <p class="help">One URL per line. The indicator shows if the site's host matches any of them.</p>
            <label for="i-label">Environment label</label>
            <input type="text" id="i-label" name="IntegrationLabel" value="@Model.IntegrationLabel" placeholder="integration" maxlength="24" />
            <p class="help">Leave blank to use the environment name. Keep it short — it sits in the top bar.</p>
            <label>Badge colour</label>
            <div class="color-row">
                <input type="color" name="IntegrationColor" value="@(Model.IntegrationColor ?? "#d4651a")" />
                <span class="color-hint">Shown as indicator background.</span>
            </div>
            <div class="checkbox-row">
                <input type="checkbox" id="disable-integration" name="IntegrationDisabled" value="true" @(Model.IntegrationDisabled ? "checked" : "") />
                <label for="disable-integration">Disable indicator in this environment</label>
            </div>
        </div>

        <div class="env">
            <h2>Preproduction</h2>
            <label for="p-url">Base URLs</label>
            <textarea id="p-url" name="PreproductionBaseUrl" rows="3"
                placeholder="https://your-prep-slot.dxcloud.episerver.net">@Model.PreproductionBaseUrl</textarea>
            <p class="help">One URL per line. The indicator shows if the site's host matches any of them.</p>
            <label for="p-label">Environment label</label>
            <input type="text" id="p-label" name="PreproductionLabel" value="@Model.PreproductionLabel" placeholder="preproduction" maxlength="24" />
            <p class="help">Leave blank to use the environment name. Keep it short — it sits in the top bar.</p>
            <label>Badge colour</label>
            <div class="color-row">
                <input type="color" name="PreproductionColor" value="@(Model.PreproductionColor ?? "#7b2fff")" />
                <span class="color-hint">Shown as indicator background.</span>
            </div>
            <div class="checkbox-row">
                <input type="checkbox" id="disable-preproduction" name="PreproductionDisabled" value="true" @(Model.PreproductionDisabled ? "checked" : "") />
                <label for="disable-preproduction">Disable indicator in this environment</label>
            </div>
        </div>

        <div class="env">
            <h2>Production</h2>
            <label for="pr-url">Base URLs</label>
            <textarea id="pr-url" name="ProductionBaseUrl" rows="3"
                placeholder="https://www.example.com">@Model.ProductionBaseUrl</textarea>
            <p class="help">One URL per line. The indicator shows if the site's host matches any of them.</p>
            <label for="pr-label">Environment label</label>
            <input type="text" id="pr-label" name="ProductionLabel" value="@Model.ProductionLabel" placeholder="production" maxlength="24" />
            <p class="help">Leave blank to use the environment name. Keep it short — it sits in the top bar.</p>
            <label>Badge colour</label>
            <div class="color-row">
                <input type="color" name="ProductionColor" value="@(Model.ProductionColor ?? "#c0392b")" />
                <span class="color-hint">Shown as indicator background.</span>
            </div>
            <div class="checkbox-row">
                <input type="checkbox" id="disable-production" name="ProductionDisabled" value="true" @(Model.ProductionDisabled ? "checked" : "") />
                <label for="disable-production">Disable indicator in this environment</label>
            </div>
        </div>

        <details class="advanced" @(string.IsNullOrWhiteSpace(Model.Selector) ? "" : "open")>
            <summary>Advanced settings</summary>
            <div class="advanced-body">
                <label for="selector">Top-bar selector override</label>
                <p class="help">
                    The CSS selector for the top-bar element the badge is placed next to. You should only need
                    this if an Optimizely CMS update moves the environment label and the badge stops appearing —
                    set it to the new element's selector to fix placement without a package update. Leave blank
                    to use the built-in default.
                </p>
                <input type="text" id="selector" name="Selector" value="@Model.Selector" placeholder="@EnvironmentClientResourceController.DefaultSelector" />
                <p class="help">Default: <code>@EnvironmentClientResourceController.DefaultSelector</code></p>
            </div>
        </details>

        <button type="submit">Save Settings</button>
    </form>

</body>
</html>
