@model MP.DxpEnvironmentIndicator.Models.EnvironmentSettingsViewModel
@using MP.DxpEnvironmentIndicator.Controllers
@using MP.DxpEnvironmentIndicator.Services
@using System.Globalization
@{
    Layout = null;

    // Derive the versioned shell resource base path from the EPiServer.Shell assembly version.
    // This avoids hardcoding the version and stays correct across CMS 13 patch releases.
    var shellAsm = typeof(EPiServer.Shell.Navigation.IMenuProvider).Assembly.GetName().Version;
    var shellVer = $"{shellAsm!.Major}.{shellAsm.Minor}.{shellAsm.Build}";
    var shellBase = $"/Optimizely/Shell/{shellVer}";

    var uiCulture   = CultureInfo.CurrentUICulture;
    var contCulture = CultureInfo.CurrentCulture;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=Edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Environment Labels</title>
    <style>
        body { margin: 0; }
        .env-settings-wrapper {
            font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            font-size: 14px; color: #1a1a1a; background: #fff; padding: 24px 28px; line-height: 1.5;
        }
        h1 { font-size: 20px; font-weight: 600; margin: 0 0 4px; }
        .sub { color: #555; margin: 0 0 20px; max-width: 720px; }
        .intro { background: #f4f8ff; border: 1px solid #d6e4fb; border-radius: 6px; padding: 14px 16px; margin-bottom: 24px; max-width: 720px; }
        .intro p { margin: 0 0 8px; } .intro p:last-child { margin-bottom: 0; }
        .env { border: 1px solid #e3e3e3; border-radius: 6px; padding: 16px 18px; margin-bottom: 16px; max-width: 720px; }
        .env h2 { font-size: 15px; font-weight: 600; margin: 0 0 12px; }
        label { display: block; font-size: 13px; font-weight: 500; color: #333; margin: 0 0 4px; }
        input[type=text] { width: 100%; max-width: 480px; padding: 7px 9px; border: 1px solid #bbb; border-radius: 3px; font-size: 14px; margin-bottom: 12px; background: #fff; color: #1a1a1a; }
        textarea { width: 100%; max-width: 480px; padding: 7px 9px; border: 1px solid #bbb; border-radius: 3px; font-size: 14px; margin-bottom: 4px; background: #fff; color: #1a1a1a; font-family: inherit; resize: vertical; display: block; }
        input[type=text]:focus, input[type=color]:focus, textarea:focus { outline: none; border-color: #2973c3; box-shadow: 0 0 0 2px rgba(41,115,195,0.2); }
        .color-row { display: flex; align-items: center; gap: 10px; }
        input[type=color] { width: 42px; height: 30px; padding: 0; border: 1px solid #bbb; border-radius: 3px; background: #fff; cursor: pointer; }
        .color-hint { color: #777; font-size: 12px; }
        .badge-preview {
            display: inline-flex; align-items: center; height: 22px; padding: 0 8px;
            border-radius: 3px; font-size: 11px; font-weight: 700; letter-spacing: 0.5px;
            white-space: nowrap; color: #fff; background: #888; margin-left: 4px;
        }
        .checkbox-row { display: flex; align-items: center; gap: 8px; margin: 12px 0 4px; max-width: 720px; }
        .checkbox-row label { margin: 0; font-weight: 400; }
        button { display: inline-block; padding: 9px 18px; font-size: 14px; font-weight: 500; cursor: pointer; border-radius: 3px; background: #2973c3; color: #fff; border: none; }
        button:hover { background: #1f5ea3; }
        .saved { background: #e8f5e9; color: #1b5e20; border: 1px solid #a5d6a7; padding: 9px 12px; border-radius: 4px; margin-bottom: 18px; max-width: 720px; }
        .error { background: #fdecea; color: #b71c1c; border: 1px solid #ef9a9a; padding: 9px 12px; border-radius: 4px; margin-bottom: 18px; max-width: 720px; }
        details.advanced { max-width: 720px; margin: 0 0 22px; border: 1px solid #e3e3e3; border-radius: 6px; }
        details.advanced > summary { cursor: pointer; padding: 12px 16px; font-weight: 600; font-size: 14px; list-style: none; user-select: none; }
        details.advanced > summary::-webkit-details-marker { display: none; }
        details.advanced > summary::before { content: '\25B8'; display: inline-block; margin-right: 8px; color: #888; transition: transform 0.15s; }
        details.advanced[open] > summary::before { transform: rotate(90deg); }
        .advanced-body { padding: 0 16px 16px; }
        .help { color: #777; font-size: 12px; margin: 0 0 12px; max-width: 640px; }
        code { background: #f3f4f6; border: 1px solid #e3e3e3; border-radius: 3px; padding: 1px 5px; font-size: 12px; word-break: break-all; }
    </style>
</head>
<body class="epi-workspace">
    @Html.AntiForgeryToken()

    <!--
        Render the Optimizely shell navigation manually (equivalent to <platform-navigation />).
        The navigation bundle reads the data-epi-* attributes to initialise the sidebar nav.
    -->
    <link href="@shellBase/ClientResources/axiom/styles.css" rel="stylesheet" type="text/css" />
    <div class="epi-navigation epi-navigation-container epi-navigationContainer"
         data-epi-antiforgery-form-field-name="__RequestVerificationToken"
         data-epi-antiforgery-header-name="RequestVerificationToken"
         data-epi-content-language="@contCulture.TwoLetterISOLanguageName"
         data-epi-current-culture="@contCulture.Name"
         data-epi-current-ui-culture="@uiCulture.TwoLetterISOLanguageName"
         data-epi-parent-product=""
         data-epi-product-id="global_cms"
         data-epi-shell-url="/Optimizely/Shell/"
         id="epi-navigation-root"></div>
    <link href="@shellBase/ClientResources/navigation/navigation.bundle.css" rel="stylesheet" type="text/css" />
    <script src="@shellBase/ClientResources/navigation/navigation.bundle.js" type="module"></script>

    <div class="epi-pn-navigation--fixed-adjust">
        <div class="env-settings-wrapper">
            <h1>Environment Labels</h1>
            <p class="sub">Badge this environment into the CMS top bar so editors always know which environment they're working in.</p>

            @if (Model.Saved) { <div class="saved">&#10003; Settings saved.</div> }
            @if (!string.IsNullOrEmpty(Model.ErrorMessage)) { <div class="error">@Model.ErrorMessage</div> }

            <div class="intro">
                <p><strong>How it works:</strong> this add-in runs in one environment, so set the label and colour for
                <em>this</em> environment. They're stored per environment, so set them once on each slot.</p>
            </div>

            <form method="post" action="@Context.Request.Path">
                @Html.AntiForgeryToken()

                <div class="env">
                    <div class="checkbox-row" style="margin-top:0">
                        <input type="checkbox" id="enabled" name="Enabled" value="true" @(Model.Enabled ? "checked" : "") />
                        <label for="enabled">Show the environment badge</label>
                    </div>

                    <label for="label">Label</label>
                    <input type="text" id="label" name="Label" value="@Model.Label" placeholder="e.g. UAT" maxlength="24" />
                    <p class="help">The text shown in the badge. Leave blank to use the server environment name. Keep it short — it sits in the top bar.</p>

                    <label>Colour</label>
                    <div class="color-row">
                        <input type="color" id="color" name="Color" value="@(Model.Color ?? EnvironmentResolver.DefaultColor)" />
                        <span class="color-hint">Shown as the badge background.</span>
                        <span class="badge-preview" id="preview">ENVIRONMENT</span>
                    </div>
                </div>

                <details class="advanced" @(string.IsNullOrWhiteSpace(Model.Selector) ? "" : "open")>
                    <summary>Advanced settings</summary>
                    <div class="advanced-body">
                        <label for="selector">Top-bar selector override</label>
                        <p class="help">Only needed if a CMS update moves the environment label and the badge stops appearing. Leave blank to use the built-in default.</p>
                        <input type="text" id="selector" name="Selector" value="@Model.Selector" placeholder="@EnvironmentClientResourceController.DefaultSelector" />
                        <p class="help">Default: <code>@EnvironmentClientResourceController.DefaultSelector</code></p>
                    </div>
                </details>

                <button type="submit">Save Settings</button>
            </form>
        </div>
    </div>

    <script>
        // Live preview of each environment's badge: updates as the colour/label change, with the same
        // WCAG-contrast text colour the server bakes into the real badge (luminance crossover 0.179).
        (function () {
            function contrastText(hex) {
                var m = /^#?([0-9a-f]{3}|[0-9a-f]{6})$/i.exec((hex || '').trim());
                if (!m) return '#ffffff';
                var h = m[1];
                if (h.length === 3) h = h[0] + h[0] + h[1] + h[1] + h[2] + h[2];
                function lin(c) { c /= 255; return c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4); }
                var L = 0.2126 * lin(parseInt(h.substr(0, 2), 16))
                      + 0.7152 * lin(parseInt(h.substr(2, 2), 16))
                      + 0.0722 * lin(parseInt(h.substr(4, 2), 16));
                return L > 0.179 ? '#1a1a1a' : '#ffffff';
            }

            var labelEl = document.getElementById('label');
            var colorEl = document.getElementById('color');
            var pill = document.getElementById('preview');
            if (!pill || !colorEl) return;
            function update() {
                pill.textContent = (labelEl && labelEl.value.trim()) || 'ENVIRONMENT';
                pill.style.background = colorEl.value;
                pill.style.color = contrastText(colorEl.value);
            }
            if (labelEl) labelEl.addEventListener('input', update);
            colorEl.addEventListener('input', update);
            update();
        })();
    </script>
</body>
</html>
